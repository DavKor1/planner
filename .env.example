# ──────────────────────────────────────────────────────────────
# Planner — environment variables
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.example .env.local
#
# NEVER commit .env.local — it is gitignored. Only this example file
# (with placeholder values) belongs in version control.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in your Supabase project: Settings → API
# The URL and anon key are safe to expose to the browser (they are
# protected by Row Level Security). The service-role key is NOT —
# keep it server-side only and never prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only

# ── Google OAuth (optional) ───────────────────────────────────
# Configure in Supabase: Authentication → Providers → Google.
# These are set in the Supabase dashboard, but kept here for reference
# if you wire the consent screen yourself.
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ── AI extraction (Anthropic) ─────────────────────────────────
# Used by the document-extraction endpoint. Server-side only.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── App ───────────────────────────────────────────────────────
# Base URL of the deployed app — used for OAuth redirects & emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
